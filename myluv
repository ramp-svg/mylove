<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MediaVault - Upload & Manage Your Media</title>
    <style>
        /* ===== RESET & BASE ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0f0f1a;
            color: #ffffff;
            min-height: 100vh;
        }

        /* ===== NAVBAR ===== */
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(15, 15, 26, 0.95);
            backdrop-filter: blur(15px);
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            border-bottom: 1px solid rgba(139, 92, 246, 0.2);
        }

        .logo {
            font-size: 1.8em;
            font-weight: 800;
            background: linear-gradient(135deg, #8b5cf6, #06b6d4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 25px;
            align-items: center;
        }

        .nav-links a {
            color: #aaa;
            text-decoration: none;
            font-size: 0.95em;
            transition: color 0.3s;
            cursor: pointer;
        }

        .nav-links a:hover, .nav-links a.active {
            color: #8b5cf6;
        }

        .nav-btn {
            padding: 10px 25px;
            background: linear-gradient(135deg, #8b5cf6, #06b6d4);
            border: none;
            border-radius: 25px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .nav-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 20px rgba(139, 92, 246, 0.4);
        }

        .hamburger {
            display: none;
            flex-direction: column;
            cursor: pointer;
            gap: 5px;
        }

        .hamburger span {
            width: 25px;
            height: 3px;
            background: white;
            border-radius: 3px;
            transition: 0.3s;
        }

        /* ===== HERO SECTION ===== */
        .hero {
            padding: 140px 40px 80px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(139, 92, 246, 0.15), transparent);
            border-radius: 50%;
            top: -200px;
            left: 50%;
            transform: translateX(-50%);
        }

        .hero h1 {
            font-size: 3.5em;
            font-weight: 800;
            margin-bottom: 15px;
            line-height: 1.2;
        }

        .hero h1 span {
            background: linear-gradient(135deg, #8b5cf6, #06b6d4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            font-size: 1.2em;
            color: #888;
            max-width: 600px;
            margin: 0 auto 30px;
        }

        .hero-stats {
            display: flex;
            justify-content: center;
            gap: 50px;
            margin-top: 40px;
        }

        .hero-stats .stat-item h3 {
            font-size: 2em;
            background: linear-gradient(135deg, #8b5cf6, #06b6d4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-stats .stat-item p {
            font-size: 0.9em;
            color: #666;
        }

        /* ===== MAIN CONTAINER ===== */
        .main-container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 40px 60px;
        }

        /* ===== TAB NAVIGATION ===== */
        .tab-nav {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            background: #1a1a2e;
            border-radius: 15px;
            padding: 8px;
            width: fit-content;
        }

        .tab-btn {
            padding: 12px 30px;
            background: transparent;
            border: none;
            color: #888;
            font-size: 1em;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .tab-btn.active {
            background: linear-gradient(135deg, #8b5cf6, #06b6d4);
            color: white;
        }

        .tab-btn:hover:not(.active) {
            color: #fff;
            background: rgba(139, 92, 246, 0.2);
        }

        /* ===== UPLOAD AREA ===== */
        .upload-section {
            margin-bottom: 50px;
        }

        .upload-area {
            border: 2px dashed rgba(139, 92, 246, 0.4);
            border-radius: 20px;
            padding: 60px 40px;
            text-align: center;
            background: rgba(26, 26, 46, 0.5);
            transition: all 0.3s;
            cursor: pointer;
            position: relative;
        }

        .upload-area:hover, .upload-area.drag-over {
            border-color: #8b5cf6;
            background: rgba(139, 92, 246, 0.1);
            transform: scale(1.01);
        }

        .upload-area.drag-over {
            box-shadow: 0 0 40px rgba(139, 92, 246, 0.3);
        }

        .upload-icon {
            font-size: 4em;
            margin-bottom: 20px;
            display: block;
        }

        .upload-area h3 {
            font-size: 1.5em;
            margin-bottom: 10px;
        }

        .upload-area p {
            color: #888;
            margin-bottom: 25px;
        }

        .upload-area .browse-btn {
            padding: 12px 35px;
            background: linear-gradient(135deg, #8b5cf6, #06b6d4);
            border: none;
            border-radius: 25px;
            color: white;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .upload-area .browse-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 25px rgba(139, 92, 246, 0.4);
        }

        .upload-area .file-info {
            margin-top: 15px;
            font-size: 0.85em;
            color: #666;
        }

        #fileInput {
            display: none;
        }

        /* ===== UPLOAD QUEUE ===== */
        .upload-queue {
            margin-top: 30px;
        }

        .upload-queue h3 {
            font-size: 1.3em;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .queue-item {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #1a1a2e;
            border-radius: 12px;
            padding: 15px 20px;
            margin-bottom: 10px;
            border: 1px solid #2a2a3e;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .queue-item .file-thumb {
            width: 50px;
            height: 50px;
            border-radius: 8px;
            object-fit: cover;
            background: #2a2a3e;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5em;
            flex-shrink: 0;
        }

        .queue-item .file-thumb img,
        .queue-item .file-thumb video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 8px;
        }

        .queue-item .file-details {
            flex: 1;
        }

        .queue-item .file-name {
            font-weight: 600;
            font-size: 0.95em;
            margin-bottom: 5px;
            word-break: break-all;
        }

        .queue-item .file-size {
            font-size: 0.8em;
            color: #888;
        }

        .progress-bar {
            width: 100%;
            height: 6px;
            background: #2a2a3e;
            border-radius: 10px;
            margin-top: 8px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(135deg, #8b5cf6, #06b6d4);
            border-radius: 10px;
            transition: width 0.3s ease;
            width: 0%;
        }

        .queue-item .file-status {
            font-size: 0.85em;
            padding: 5px 12px;
            border-radius: 20px;
            font-weight: 600;
            flex-shrink: 0;
        }

        .status-uploading {
            background: rgba(234, 179, 8, 0.2);
            color: #eab308;
        }

        .status-complete {
            background: rgba(34, 197, 94, 0.2);
            color: #22c55e;
        }

        .status-error {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
        }

        .queue-item .remove-btn {
            background: none;
            border: none;
            color: #666;
            font-size: 1.2em;
            cursor: pointer;
            transition: color 0.3s;
            padding: 5px;
        }

        .queue-item .remove-btn:hover {
            color: #ef4444;
        }

        /* ===== TOOLBAR ===== */
        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .toolbar-left {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .search-box {
            display: flex;
            align-items: center;
            background: #1a1a2e;
            border: 1px solid #2a2a3e;
            border-radius: 10px;
            padding: 10px 15px;
            gap: 10px;
            transition: border-color 0.3s;
        }

        .search-box:focus-within {
            border-color: #8b5cf6;
        }

        .search-box input {
            background: none;
            border: none;
            color: white;
            font-size: 0.95em;
            outline: none;
            width: 200px;
        }

        .search-box input::placeholder {
            color: #555;
        }

        .filter-select {
            padding: 10px 15px;
            background: #1a1a2e;
            border: 1px solid #2a2a3e;
            border-radius: 10px;
            color: white;
            font-size: 0.95em;
            cursor: pointer;
            outline: none;
        }

        .filter-select option {
            background: #1a1a2e;
        }

        .toolbar-right {
            display: flex;
            gap: 10px;
        }

        .view-btn {
            padding: 10px 15px;
            background: #1a1a2e;
            border: 1px solid #2a2a3e;
            border-radius: 10px;
            color: #888;
            cursor: pointer;
            font-size: 1.1em;
            transition: all 0.3s;
        }

        .view-btn.active {
            border-color: #8b5cf6;
            color: #8b5cf6;
        }

        .delete-selected-btn {
            padding: 10px 20px;
            background: rgba(239, 68, 68, 0.2);
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 10px;
            color: #ef4444;
            cursor: pointer;
            font-size: 0.9em;
            font-weight: 600;
            transition: all 0.3s;
            display: none;
        }

        .delete-selected-btn.visible {
            display: block;
        }

        .delete-selected-btn:hover {
            background: rgba(239, 68, 68, 0.3);
        }

        /* ===== MEDIA GALLERY ===== */
        .gallery {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        .gallery.list-view {
            grid-template-columns: 1fr;
        }

        .media-card {
            background: #1a1a2e;
            border-radius: 15px;
            overflow: hidden;
            border: 1px solid #2a2a3e;
            transition: all 0.3s;
            position: relative;
            animation: fadeInUp 0.4s ease;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .media-card:hover {
            transform: translateY(-5px);
            border-color: #8b5cf6;
            box-shadow: 0 15px 40px rgba(139, 92, 246, 0.15);
        }

        .media-card .select-checkbox {
            position: absolute;
            top: 12px;
            left: 12px;
            width: 22px;
            height: 22px;
            border-radius: 6px;
            border: 2px solid rgba(255, 255, 255, 0.5);
            background: rgba(0, 0, 0, 0.5);
            cursor: pointer;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            opacity: 0;
        }

        .media-card:hover .select-checkbox,
        .media-card .select-checkbox.checked {
            opacity: 1;
        }

        .media-card .select-checkbox.checked {
            background: #8b5cf6;
            border-color: #8b5cf6;
        }

        .media-preview {
            width: 100%;
            height: 200px;
            position: relative;
            overflow: hidden;
            background: #12121f;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .media-preview img,
        .media-preview video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .media-preview .play-overlay {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 50px;
            height: 50px;
            background: rgba(139, 92, 246, 0.9);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2em;
            opacity: 0;
            transition: opacity 0.3s;
            cursor: pointer;
        }

        .media-card:hover .play-overlay {
            opacity: 1;
        }

        .media-preview .media-type-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75em;
            font-weight: 600;
            backdrop-filter: blur(10px);
        }

        .badge-image {
            background: rgba(34, 197, 94, 0.3);
            color: #22c55e;
        }

        .badge-video {
            background: rgba(139, 92, 246, 0.3);
            color: #8b5cf6;
        }

        .media-info {
            padding: 15px;
        }

        .media-info .media-name {
            font-weight: 600;
            font-size: 0.95em;
            margin-bottom: 8px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .media-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #666;
            font-size: 0.8em;
        }

        .media-actions {
            display: flex;
            gap: 8px;
            padding: 0 15px 15px;
        }

        .media-actions button {
            flex: 1;
            padding: 8px;
            border: 1px solid #2a2a3e;
            border-radius: 8px;
            background: transparent;
            color: #aaa;
            cursor: pointer;
            font-size: 0.85em;
            transition: all 0.3s;
        }

        .media-actions button:hover {
            border-color: #8b5cf6;
            color: #8b5cf6;
            background: rgba(139, 92, 246, 0.1);
        }

        .media-actions .delete-btn:hover {
            border-color: #ef4444;
            color: #ef4444;
            background: rgba(239, 68, 68, 0.1);
        }

        /* ===== LIST VIEW ===== */
        .gallery.list-view .media-card {
            display: flex;
            align-items: center;
        }

        .gallery.list-view .media-preview {
            width: 120px;
            height: 80px;
            flex-shrink: 0;
        }

        .gallery.list-view .media-info {
            flex: 1;
        }

        .gallery.list-view .media-actions {
            flex-shrink: 0;
            padding: 15px;
        }

        /* ===== LIGHTBOX / MODAL ===== */
        .lightbox {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            z-index: 2000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 40px;
        }

        .lightbox.active {
            display: flex;
        }

        .lightbox-content {
            max-width: 90%;
            max-height: 90%;
            position: relative;
        }

        .lightbox-content img,
        .lightbox-content video {
            max-width: 100%;
            max-height: 80vh;
            border-radius: 10px;
        }

        .lightbox-close {
            position: absolute;
            top: -40px;
            right: 0;
            background: none;
            border: none;
            color: white;
            font-size: 2em;
            cursor: pointer;
            transition: color 0.3s;
        }

        .lightbox-close:hover {
            color: #ef4444;
        }

        .lightbox-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(139, 92, 246, 0.3);
            border: none;
            color: white;
            font-size: 1.5em;
            padding: 15px 20px;
            cursor: pointer;
            border-radius: 10px;
            transition: all 0.3s;
        }

        .lightbox-nav:hover {
            background: rgba(139, 92, 246, 0.6);
        }

        .lightbox-prev { left: -70px; }
        .lightbox-next { right: -70px; }

        .lightbox-info {
            text-align: center;
            margin-top: 15px;
            color: #aaa;
        }

        /* ===== EMPTY STATE ===== */
        .empty-state {
            text-align: center;
            padding: 80px 20px;
            color: #555;
        }

        .empty-state .empty-icon {
            font-size: 5em;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .empty-state h3 {
            font-size: 1.5em;
            color: #888;
            margin-bottom: 10px;
        }

        /* ===== STORAGE BAR ===== */
        .storage-info {
            background: #1a1a2e;
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 30px;
            border: 1px solid #2a2a3e;
        }

        .storage-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .storage-header h3 {
            font-size: 1.1em;
        }

        .storage-header span {
            color: #888;
            font-size: 0.9em;
        }

        .storage-bar {
            width: 100%;
            height: 10px;
            background: #2a2a3e;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 15px;
        }

        .storage-fill {
            height: 100%;
            background: linear-gradient(135deg, #8b5cf6, #06b6d4);
            border-radius: 10px;
            transition: width 0.5s ease;
        }

        .storage-details {
            display: flex;
            gap: 30px;
        }

        .storage-detail {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85em;
            color: #888;
        }

        .storage-detail .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

        .dot-images { background: #8b5cf6; }
        .dot-videos { background: #06b6d4; }
        .dot-free { background: #2a2a3e; }

        /* ===== TOAST NOTIFICATION ===== */
        .toast-container {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 3000;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .toast {
            padding: 15px 25px;
            border-radius: 12px;
            color: white;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: toastIn 0.3s ease, toastOut 0.3s ease 2.7s;
            min-width: 300px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .toast-success {
            background: linear-gradient(135deg, #059669, #10b981);
        }

        .toast-error {
            background: linear-gradient(135deg, #dc2626, #ef4444);
        }

        .toast-info {
            background: linear-gradient(135deg, #7c3aed, #8b5cf6);
        }

        @keyframes toastIn {
            from { opacity: 0; transform: translateX(100px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @keyframes toastOut {
            from { opacity: 1; transform: translateX(0); }
            to { opacity: 0; transform: translateX(100px); }
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .navbar {
                padding: 15px 20px;
            }

            .nav-links {
                display: none;
                position: absolute;
                top: 60px;
                left: 0;
                width: 100%;
                background: rgba(15, 15, 26, 0.98);
                flex-direction: column;
                padding: 20px;
                gap: 15px;
                border-bottom: 1px solid #2a2a3e;
            }

            .nav-links.active {
                display: flex;
            }

            .hamburger {
                display: flex;
            }

            .hero {
                padding: 120px 20px 60px;
            }

            .hero h1 {
                font-size: 2.2em;
            }

            .hero-stats {
                gap: 25px;
            }

            .main-container {
                padding: 0 20px 40px;
            }

            .gallery {
                grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            }

            .toolbar {
                flex-direction: column;
                align-items: stretch;
            }

            .toolbar-left {
                flex-direction: column;
            }

            .search-box input {
                width: 100%;
            }

            .upload-area {
                padding: 40px 20px;
            }

            .tab-nav {
                width: 100%;
                overflow-x: auto;
            }

            .lightbox-prev { left: 10px; }
            .lightbox-next { right: 10px; }

            .storage-details {
                flex-direction: column;
                gap: 10px;
            }

            .contact-container {
                flex-direction: column;
            }
        }

        @media (max-width: 480px) {
            .hero h1 { font-size: 1.8em; }
            .gallery { grid-template-columns: 1fr; }
            .hero-stats { flex-direction: column; gap: 15px; }
        }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #0f0f1a;
        }

        ::-webkit-scrollbar-thumb {
            background: #2a2a3e;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #8b5cf6;
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="logo">📁 MediaVault</div>
        <ul class="nav-links" id="navLinks">
            <li><a href="#" class="active" onclick="showSection('upload')">Upload</a></li>
            <li><a href="#" onclick="showSection('gallery')">Gallery</a></li>
            <li><a href="#" onclick="showSection('gallery'); filterMedia('images')">Images</a></li>
            <li><a href="#" onclick="showSection('gallery'); filterMedia('videos')">Videos</a></li>
            <li><button class="nav-btn" onclick="document.getElementById('fileInput').click()">+ Upload</button></li>
        </ul>
        <div class="hamburger" id="hamburger">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </nav>

    <!-- TOAST CONTAINER -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- HERO SECTION -->
    <section class="hero" id="heroSection">
        <h1>Upload & Manage Your <span>Media</span></h1>
        <p>Store your images and videos securely. Drag, drop, and organize your media files with ease.</p>
        <div class="hero-stats">
            <div class="stat-item">
                <h3 id="totalFiles">0</h3>
                <p>Total Files</p>
            </div>
            <div class="stat-item">
                <h3 id="totalImages">0</h3>
                <p>Images</p>
            </div>
            <div class="stat-item">
                <h3 id="totalVideos">0</h3>
                <p>Videos</p>
            </div>
            <div class="stat-item">
                <h3 id="totalSize">0 MB</h3>
                <p>Storage Used</p>
            </div>
        </div>
    </section>

    <!-- MAIN CONTAINER -->
    <div class="main-container">

        <!-- STORAGE INFO -->
        <div class="storage-info">
            <div class="storage-header">
                <h3>💾 Storage</h3>
                <span id="storageText">0 MB of 500 MB used</span>
            </div>
            <div class="storage-bar">
                <div class="storage-fill" id="storageFill" style="width: 0%"></div>
            </div>
            <div class="storage-details">
                <div class="storage-detail">
                    <div class="dot dot-images"></div>
                    <span>Images: <strong id="imageStorage">0 MB</strong></span>
                </div>
                <div class="storage-detail">
                    <div class="dot dot-videos"></div>
                    <span>Videos: <strong id="videoStorage">0 MB</strong></span>
                </div>
                <div class="storage-detail">
                    <div class="dot dot-free"></div>
                    <span>Free: <strong id="freeStorage">500 MB</strong></span>
                </div>
            </div>
        </div>

        <!-- TAB NAVIGATION -->
        <div class="tab-nav">
            <button class="tab-btn active" onclick="switchTab(this, 'upload')">📤 Upload</button>
            <button class="tab-btn" onclick="switchTab(this, 'gallery')">🖼️ Gallery</button>
        </div>

        <!-- UPLOAD SECTION -->
        <div class="upload-section" id="uploadSection">
            <div class="upload-area" id="uploadArea">
                <input type="file" id="fileInput" multiple accept="image/*,video/*">
                <span class="upload-icon">☁️</span>
                <h3>Drag & Drop your files here</h3>
                <p>or click to browse from your computer</p>
                <button class="browse-btn" onclick="document.getElementById('fileInput').click()">
                    📂 Browse Files
                </button>
                <p class="file-info">Supports: JPG, PNG, GIF, WEBP, MP4, MOV, AVI, WEBM (Max 100MB per file)</p>
            </div>

            <!-- UPLOAD QUEUE -->
            <div class="upload-queue" id="uploadQueue" style="display: none;">
                <h3>📋 Upload Queue <span id="queueCount"></span></h3>
                <div id="queueList"></div>
            </div>
        </div>

        <!-- GALLERY SECTION -->
        <div id="gallerySection" style="display: none;">
            <!-- TOOLBAR -->
            <div class="toolbar">
                <div class="toolbar-left">
                    <div class="search-box">
                        <span>🔍</span>
                        <input type="text" placeholder="Search files..." id="searchInput" oninput="searchMedia()">
                    </div>
                    <select class="filter-select" id="filterSelect" onchange="applyFilter()">
                        <option value="all">All Files</option>
                        <option value="images">Images Only</option>
                        <option value="videos">Videos Only</option>
                    </select>
                    <select class="filter-select" id="sortSelect" onchange="sortMedia()">
                        <option value="newest">Newest First</option>
                        <option value="oldest">Oldest First</option>
                        <option value="name">By Name</option>
                        <option value="size">By Size</option>
                    </select>
                </div>
                <div class="toolbar-right">
                    <button class="delete-selected-btn" id="deleteSelectedBtn" onclick="deleteSelected()">
                        🗑️ Delete Selected (<span id="selectedCount">0</span>)
                    </button>
                    <button class="view-btn active" id="gridViewBtn" onclick="setView('grid')">▦</button>
                    <button class="view-btn" id="listViewBtn" onclick="setView('list')">☰</button>
                </div>
            </div>

            <!-- GALLERY GRID -->
            <div class="gallery" id="gallery">
                <div class="empty-state" id="emptyState">
                    <div class="empty-icon">📭</div>
                    <h3>No media files yet</h3>
                    <p>Upload some images or videos to get started!</p>
                </div>
            </div>
        </div>
    </div>

    <!-- LIGHTBOX -->
    <div class="lightbox" id="lightbox">
        <div class="lightbox-content" id="lightboxContent">
            <button class="lightbox-close" onclick="closeLightbox()">✕</button>
            <button class="lightbox-nav lightbox-prev" onclick="navigateLightbox(-1)">◀</button>
            <button class="lightbox-nav lightbox-next" onclick="navigateLightbox(1)">▶</button>
            <div id="lightboxMedia"></div>
            <div class="lightbox-info" id="lightboxInfo"></div>
        </div>
    </div>

    <!-- JAVASCRIPT -->
    <script>
        // ===== STATE MANAGEMENT =====
        let mediaFiles = [];
        let selectedFiles = new Set();
        let currentLightboxIndex = -1;
        let currentFilter = 'all';
        let currentView = 'grid';
        const MAX_STORAGE = 500 * 1024 * 1024; // 500MB

        // ===== INITIALIZATION =====
        document.addEventListener('DOMContentLoaded', () => {
            loadFromStorage();
            setupDragAndDrop();
            setupFileInput();
            setupHamburger();
            updateStats();
        });

        // ===== HAMBURGER MENU =====
        function setupHamburger() {
            const hamburger = document.getElementById('hamburger');
            const navLinks = document.getElementById('navLinks');
            hamburger.addEventListener('click', () => {
                navLinks.classList.toggle('active');
            });
        }

        // ===== DRAG AND DROP =====
        function setupDragAndDrop() {
            const uploadArea = document.getElementById('uploadArea');

            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(event => {
                uploadArea.addEventListener(event, (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                });
            });

            ['dragenter', 'dragover'].forEach(event => {
                uploadArea.addEventListener(event, () => {
                    uploadArea.classList.add('drag-over');
                });
            });

            ['dragleave', 'drop'].forEach(event => {
                uploadArea.addEventListener(event, () => {
                    uploadArea.classList.remove('drag-over');
                });
            });

            uploadArea.addEventListener('drop', (e) => {
                const files = e.dataTransfer.files;
                handleFiles(files);
            });

            uploadArea.addEventListener('click', (e) => {
                if (e.target.tagName !== 'BUTTON') {
                    document.getElementById('fileInput').click();
                }
            });
        }

        // ===== FILE INPUT =====
        function setupFileInput() {
            document.getElementById('fileInput').addEventListener('change', (e) => {
                handleFiles(e.target.files);
                e.target.value = '';
            });
        }

        // ===== HANDLE FILES =====
        function handleFiles(files) {
            const validTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp', 'image/svg+xml',
                               'video/mp4', 'video/webm', 'video/ogg', 'video/quicktime', 'video/avi'];

            let addedCount = 0;

            Array.from(files).forEach(file => {
                // Validate type
                if (!file.type.startsWith('image/') && !file.type.startsWith('video/')) {
                    showToast(`❌ "${file.name}" is not a supported format`, 'error');
                    return;
                }

                // Validate size (100MB max per file)
                if (file.size > 100 * 1024 * 1024) {
                    showToast(`❌ "${file.name}" exceeds 100MB limit`, 'error');
                    return;
                }

                // Check storage
                const totalUsed = mediaFiles.reduce((sum, f) => sum + f.size, 0);
                if (totalUsed + file.size > MAX_STORAGE) {
                    showToast(`❌ Not enough storage for "${file.name}"`, 'error');
                    return;
                }

                addedCount++;
                processFile(file);
            });

            if (addedCount > 0) {
                showToast(`✅ ${addedCount} file(s) added successfully!`, 'success');
            }
        }

        // ===== PROCESS FILE =====
        function processFile(file) {
            const reader = new FileReader();
            const fileId = Date.now() + Math.random().toString(36).substr(2, 9);

            // Show in queue
            showInQueue(file, fileId);

            reader.onload = (e) => {
                const mediaItem = {
                    id: fileId,
                    name: file.name,
                    type: file.type.startsWith('image/') ? 'image' : 'video',
                    mimeType: file.type,
                    size: file.size,
                    data: e.target.result,
                    date: new Date().toISOString(),
                    favorite: false
                };

                // Simulate upload progress
                simulateUpload(fileId, () => {
                    mediaFiles.unshift(mediaItem);
                    saveToStorage();
                    updateStats();
                    renderGallery();
                    updateQueueStatus(fileId, 'complete');
                });
            };

            reader.onerror = () => {
                updateQueueStatus(fileId, 'error');
                showToast(`❌ Failed to read "${file.name}"`, 'error');
            };

            reader.readAsDataURL(file);
        }

        // ===== SIMULATE UPLOAD =====
        function simulateUpload(fileId, callback) {
            let progress = 0;
            const interval = setInterval(() => {
                progress += Math.random() * 25 + 5;
                if (progress >= 100) {
                    progress = 100;
                    clearInterval(interval);
                    setTimeout(callback, 200);
                }
                updateQueueProgress(fileId, Math.min(progress, 100));
            }, 150);
        }

        // ===== UPLOAD QUEUE =====
        function showInQueue(file, fileId) {
            const queue = document.getElementById('uploadQueue');
            const queueList = document.getElementById('queueList');
            queue.style.display = 'block';

            const isImage = file.type.startsWith('image/');
            const item = document.createElement('div');
            item.className = 'queue-item';
            item.id = `queue-${fileId}`;
            item.innerHTML = `
                <div class="file-thumb">${isImage ? '🖼️' : '🎥'}</div>
                <div class="file-details">
                    <div class="file-name">${file.name}</div>
                    <div class="file-size">${formatSize(file.size)}</div>
                    <div class="progress-bar">
                        <div class="progress-fill" id="progress-${fileId}"></div>
                    </div>
                </div>
                <span class="file-status status-uploading" id="status-${fileId}">Uploading...</span>
                <button class="remove-btn" onclick="removeFromQueue('${fileId}')">✕</button>
            `;

            queueList.prepend(item);
            updateQueueCount();
        }

        function updateQueueProgress(fileId, percent) {
            const progressBar = document.getElementById(`progress-${fileId}`);
            if (progressBar) {
                progressBar.style.width = percent + '%';
            }
        }

        function updateQueueStatus(fileId, status) {
            const statusEl = document.getElementById(`status-${fileId}`);
            if (statusEl) {
                if (status === 'complete') {
                    statusEl.textContent = 'Complete ✓';
                    statusEl.className = 'file-status status-complete';
                } else if (status === 'error') {
                    statusEl.textContent = 'Error ✕';
                    statusEl.className = 'file-status status-error';
                }
            }

            // Remove from queue after delay
            setTimeout(() => {
                const item = document.getElementById(`queue-${fileId}`);
                if (item) {
                    item.style.opacity = '0';
                    item.style.transform = 'translateX(20px)';
                    item.style.transition = 'all 0.3s';
                    setTimeout(() => {
                        item.remove();
                        updateQueueCount();
                    }, 300);
                }
            }, 2000);
        }

        function removeFromQueue(fileId) {
            const item = document.getElementById(`queue-${fileId}`);
            if (item) item.remove();
            updateQueueCount();
        }

        function updateQueueCount() {
            const items = document.querySelectorAll('.queue-item');
            const countEl = document.getElementById('queueCount');
            countEl.textContent = items.length > 0 ? `(${items.length})` : '';
            if (items.length === 0) {
                document.getElementById('uploadQueue').style.display = 'none';
            }
        }

        // ===== RENDER GALLERY =====
        function renderGallery() {
            const gallery = document.getElementById('gallery');
            const emptyState = document.getElementById('emptyState');
            const filtered = getFilteredMedia();

            if (filtered.length === 0) {
                gallery.innerHTML = '';
                gallery.appendChild(createEmptyState());
                return;
            }

            gallery.innerHTML = '';

            filtered.forEach((item, index) => {
                const card = document.createElement('div');
                card.className = 'media-card';
                card.setAttribute('data-id', item.id);

                const isSelected = selectedFiles.has(item.id);

                card.innerHTML = `
                    <div class="select-checkbox ${isSelected ? 'checked' : ''}" 
                         onclick="event.stopPropagation(); toggleSelect('${item.id}')">
                        ${isSelected ? '✓' : ''}
                    </div>
                    <div class="media-preview" onclick="openLightbox(${index})">
                        ${item.type === 'image'
                            ? `<img src="${item.data}" alt="${item.name}" loading="lazy">`
                            : `<video src="${item.data}" preload="metadata"></video>
                               <div class="play-overlay">▶</div>`
                        }
                        <span class="media-type-badge ${item.type === 'image' ? 'badge-image' : 'badge-video'}">
                            ${item.type === 'image' ? '📷 Image' : '🎥 Video'}
                        </span>
                    </div>
                    <div class="media-info">
                        <div class="media-name" title="${item.name}">${item.name}</div>
                        <div class="media-meta">
                            <span>${formatSize(item.size)}</span>
                            <span>${formatDate(item.date)}</span>
                        </div>
                    </div>
                    <div class="media-actions">
                        <button onclick="event.stopPropagation(); downloadFile('${item.id}')" title="Download">
                            📥 Download
                        </button>
                        <button onclick="event.stopPropagation(); renameFile('${item.id}')" title="Rename">
                            ✏️ Rename
                        </button>
                        <button class="delete-btn" onclick="event.stopPropagation(); deleteFile('${item.id}')" title="Delete">
                            🗑️ Delete
                        </button>
                    </div>
                `;

                gallery.appendChild(card);
            });
        }

        function createEmptyState() {
            const div = document.createElement('div');
            div.className = 'empty-state';
            div.id = 'emptyState';
            div.innerHTML = `
                <div class="empty-icon">📭</div>
                <h3>No media files found</h3>
                <p>Upload some images or videos to get started!</p>
            `;
            return div;
        }

        // ===== FILTER & SEARCH =====
        function getFilteredMedia() {
            let filtered = [...mediaFiles];
            const searchTerm = document.getElementById('searchInput')?.value?.toLowerCase() || '';
            const filter = document.getElementById('filterSelect')?.value || 'all';
            const sort = document.getElementById('sortSelect')?.value || 'newest';

            // Apply type filter
            if (filter === 'images') {
                filtered = filtered.filter(f => f.type === 'image');
            } else if (filter === 'videos') {
                filtered = filtered.filter(f => f.type === 'video');
            }

            // Apply search
            if (searchTerm) {
                filtered = filtered.filter(f => f.name.toLowerCase().includes(searchTerm));
            }

            // Apply sort
            switch (sort) {
                case 'newest':
                    filtered.sort((a, b) => new Date(b.date) - new Date(a.date));
                    break;
                case 'oldest':
                    filtered.sort((a, b) => new Date(a.date) - new Date(b.date));
                    break;
                case 'name':
                    filtered.sort((a, b) => a.name.localeCompare(b.name));
                    break;
                case 'size':
                    filtered.sort((a, b) => b.size - a.size);
                    break;
            }

            return filtered;
        }

        function searchMedia() { renderGallery(); }
        function applyFilter() { renderGallery(); }
        function sortMedia() { renderGallery(); }

        function filterMedia(type) {
            const filterSelect = document.getElementById('filterSelect');
            if (filterSelect) {
                filterSelect.value = type;
                renderGallery();
            }
        }

        // ===== VIEW TOGGLE =====
        function setView(view) {
            currentView = view;
            const gallery = document.getElementById('gallery');
            const gridBtn = document.getElementById('gridViewBtn');
            const listBtn = document.getElementById('listViewBtn');

            if (view === 'list') {
                gallery.classList.add('list-view');
                listBtn.classList.add('active');
                gridBtn.classList.remove('active');
            } else {
                gallery.classList.remove('list-view');
                gridBtn.classList.add('active');
                listBtn.classList.remove('active');
            }
        }

        // ===== SELECT FILES =====
        function toggleSelect(id) {
            if (selectedFiles.has(id)) {
                selectedFiles.delete(id);
            } else {
                selectedFiles.add(id);
            }
            updateSelectedUI();
            renderGallery();
        }

        function updateSelectedUI() {
            const btn = document.getElementById('deleteSelectedBtn');
            const count = document.getElementById('selectedCount');
            count.textContent = selectedFiles.size;
            btn.classList.toggle('visible', selectedFiles.size > 0);
        }

        function deleteSelected() {
            if (selectedFiles.size === 0) return;
            if (confirm(`Delete ${selectedFiles.size} selected file(s)?`)) {
                mediaFiles = mediaFiles.filter(f => !selectedFiles.has(f.id));
                showToast(`🗑️ ${selectedFiles.size} file(s) deleted`, 'info');
                selectedFiles.clear();
                updateSelectedUI();
                saveToStorage();
                updateStats();
                renderGallery();
            }
        }

        // ===== FILE OPERATIONS =====
        function deleteFile(id) {
            if (confirm('Are you sure you want to delete this file?')) {
                const file = mediaFiles.find(f => f.id === id);
                mediaFiles = mediaFiles.filter(f => f.id !== id);
                selectedFiles.delete(id);
                updateSelectedUI();
                saveToStorage();
                updateStats();
                renderGallery();
                showToast(`🗑️ "${file?.name}" deleted`, 'info');
            }
        }

        function renameFile(id) {
            const file = mediaFiles.find(f => f.id === id);
            if (!file) return;

            const newName = prompt('Enter new name:', file.name);
            if (newName && newName.trim()) {
                file.name = newName.trim();
                saveToStorage();
                renderGallery();
                showToast(`✏️ File renamed to "${newName.trim()}"`, 'success');
            }
        }

        function downloadFile(id) {
            const file = mediaFiles.find(f => f.id === id);
            if (!file) return;

            const link = document.createElement('a');
            link.href = file.data;
            link.download = file.name;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            showToast(`📥 Downloading "${file.name}"`, 'success');
        }

        // ===== LIGHTBOX =====
        function openLightbox(index) {
            const filtered = getFilteredMedia();
            currentLightboxIndex = index;
            const item = filtered[index];
            if (!item) return;

            const lightbox = document.getElementById('lightbox');
            const mediaContainer = document.getElementById('lightboxMedia');
            const info = document.getElementById('lightboxInfo');

            if (item.type === 'image') {
                mediaContainer.innerHTML = `<img src="${item.data}" alt="${item.name}">`;
            } else {
                mediaContainer.innerHTML = `<video src="${item.data}" controls autoplay style="max-width:100%; max-height:80vh; border-radius:10px;"></video>`;
            }

            info.innerHTML = `<strong>${item.name}</strong> • ${formatSize(item.size)} • ${formatDate(item.date)}`;
            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            const lightbox = document.getElementById('lightbox');
            lightbox.classList.remove('active');
            document.body.style.overflow = '';

            // Stop any playing videos
            const video = lightbox.querySelector('video');
            if (video) video.pause();
        }

        function navigateLightbox(direction) {
            const filtered = getFilteredMedia();
            currentLightboxIndex += direction;

            if (currentLightboxIndex < 0) currentLightboxIndex = filtered.length - 1;
            if (currentLightboxIndex >= filtered.length) currentLightboxIndex = 0;

            openLightbox(currentLightboxIndex);
        }

        // Keyboard navigation for lightbox
        document.addEventListener('keydown', (e) => {
            const lightbox = document.getElementById('lightbox');
            if (!lightbox.classList.contains('active')) return;

            if (e.key === 'Escape') closeLightbox();
            if (e.key === 'ArrowLeft') navigateLightbox(-1);
            if (e.key === 'ArrowRight') navigateLightbox(1);
        });

        // ===== SECTION NAVIGATION =====
        function showSection(section) {
            const uploadSection = document.getElementById('uploadSection');
            const gallerySection = document.getElementById('gallerySection');

            if (section === 'upload') {
                uploadSection.style.display = 'block';
                gallerySection.style.display = 'none';
                switchTab(document.querySelectorAll('.tab-btn')[0], 'upload');
            } else {
                uploadSection.style.display = 'none';
                gallerySection.style.display = 'block';
                switchTab(document.querySelectorAll('.tab-btn')[1], 'gallery');
                renderGallery();
            }

            // Update nav links
            document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
        }

        function switchTab(btn, section) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const uploadSection = document.getElementById('uploadSection');
            const gallerySection = document.getElementById('gallerySection');

            if (section === 'upload') {
                uploadSection.style.display = 'block';
                gallerySection.style.display = 'none';
            } else {
                uploadSection.style.display = 'none';
                gallerySection.style.display = 'block';
                renderGallery();
            }
        }

        // ===== STATS UPDATE =====
        function updateStats() {
            const images = mediaFiles.filter(f => f.type === 'image');
            const videos = mediaFiles.filter(f => f.type === 'video');
            const totalSize = mediaFiles.reduce((sum, f) => sum + f.size, 0);
            const imageSize = images.reduce((sum, f) => sum + f.size, 0);
            const videoSize = videos.reduce((sum, f) => sum + f.size, 0);

            document.getElementById('totalFiles').textContent = mediaFiles.length;
            document.getElementById('totalImages').textContent = images.length;
            document.getElementById('totalVideos').textContent = videos.length;
            document.getElementById('totalSize').textContent = formatSize(totalSize);

            // Storage bar
            const percentage = (totalSize / MAX_STORAGE) * 100;
            document.getElementById('storageFill').style.width = Math.min(percentage, 100) + '%';
            document.getElementById('storageText').textContent = `${formatSize(totalSize)} of ${formatSize(MAX_STORAGE)} used`;
            document.getElementById('imageStorage').textContent = formatSize(imageSize);
            document.getElementById('videoStorage').textContent = formatSize(videoSize);
            document.getElementById('freeStorage').textContent = formatSize(MAX_STORAGE - totalSize);
        }

        // ===== LOCAL STORAGE =====
        function saveToStorage() {
            try {
                // Save metadata separately from data to handle size limits
                const metadata = mediaFiles.map(f => ({...f}));
                localStorage.setItem('mediaVault', JSON.stringify(metadata));
            } catch (e) {
                console.warn('Storage quota exceeded, keeping files in memory only');
                showToast('⚠️ Local storage full. Files available this session only.', 'error');
            }
        }

        function loadFromStorage() {
            try {
                const data = localStorage.getItem('mediaVault');
                if (data) {
                    mediaFiles = JSON.parse(data);
                    updateStats();
                    renderGallery();
                }
            } catch (e) {
                console.warn('Could not load from storage');
            }
        }

        // ===== TOAST NOTIFICATIONS =====
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            toast.innerHTML = message;
            container.appendChild(toast);

            setTimeout(() => {
                toast.remove();
            }, 3000);
        }

        // ===== UTILITY FUNCTIONS =====
        function formatSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        function formatDate(dateString) {
            const date = new Date(dateString);
            const now = new Date();
            const diff = now - date;
            const minutes = Math.floor(diff / 60000);
            const hours = Math.floor(diff / 3600000);
            const days = Math.floor(diff / 86400000);

            if (minutes < 1) return 'Just now';
            if (minutes < 60) return `${minutes}m ago`;
            if (hours < 24) return `${hours}h ago`;
            if (days < 7) return `${days}d ago`;

            return date.toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: date.getFullYear() !== now.getFullYear() ? 'numeric' : undefined
            });
        }

        // ===== PASTE FROM CLIPBOARD =====
        document.addEventListener('paste', (e) => {
            const items = e.clipboardData?.items;
            if (!items) return;

            for (let item of items) {
                if (item.type.startsWith('image/') || item.type.startsWith('video/')) {
                    const file = item.getAsFile();
                    if (file) {
                        handleFiles([file]);
                        showToast('📋 File pasted from clipboard!', 'success');
                    }
                }
            }
        });
    </script>
</body>
</html>
